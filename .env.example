# ================================================================
# CLASS SYSTEM (QA REPO) - BACKEND ENVIRONMENT VARIABLES EXAMPLE
# Copy file này thành .env và điền giá trị thực tế vào
# ================================================================

# ===================== DATABASE (MySQL) =====================
# URL kết nối: dùng 127.0.0.1:3307 khi chạy local, mysql:3306 khi trong Docker
DB_URL=jdbc:mysql://127.0.0.1:3307/class_system
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_db_password       # VD: root-3355
DB_NAME=class_system

# ===================== SERVER =====================
SERVER_PORT=8081

# ===================== REDIS =====================
REDIS_HOST=127.0.0.1               # Dùng 'redis' khi chạy trong Docker
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password # VD: DoAn2025PTIT

# ===================== REDIS COMMANDER (UI debug Redis) =====================
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=your_commander_password

# ===================== MAIL (Gmail SMTP) =====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password    # App Password (16 ký tự từ Google Account)

# ===================== FRONTEND =====================
FRONTEND_URL=http://localhost:3000

# ===================== FILE STORAGE =====================
# URL công khai để download file
URL_DOWNLOAD_FILE=http://localhost:8081/api/files/download/
